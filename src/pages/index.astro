---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <section class="page">
    <h1>Home</h1>
    <p>
      Minimalist dark portfolio shell initialized with a shared navigation foundation for <code>/about</code>,
      <code>/projects</code>, <code>/blog</code>, and <code>/contact</code>.
    </p>
    <p class="meta">status://foundation-shell ready</p>
    <div class="section">
      <p>Use the top navigation to verify active route states, keyboard access, and responsive behavior.</p>
    </div>
  </section>
</BaseLayout>
