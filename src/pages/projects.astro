---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects">
  <section class="page">
    <h1>Projects</h1>
    <p>
      Things I'm working on outside of client work.
    </p>

    <article class="section" aria-labelledby="project-cloudmount">
      <h2 id="project-cloudmount">CloudMount</h2>
      <p>
        macOS menu bar app that mounts Backblaze B2 buckets as native Finder volumes. Uses Apple's FSKit framework so
        it just shows up as a regular folder. Written in Swift, no FUSE, no kernel extensions. Currently macOS 26+
        only.
      </p>
      <p>
        <a href="https://github.com/ebreen/cloudmount" target="_blank" rel="noreferrer">github.com/ebreen/cloudmount</a>
      </p>
    </article>

    <article class="section" aria-labelledby="project-solana-agent-toolkit">
      <h2 id="project-solana-agent-toolkit">Solana Agent Toolkit</h2>
      <p>
        27 JavaScript tools for Solana development. Wallet ops, token management, Jupiter swaps, yield tracking,
        NFT minting, DCA bots. Designed for AI agents to call programmatically.
      </p>
      <p>
        <a href="https://github.com/ebreen/solana-agent-toolkit" target="_blank" rel="noreferrer">github.com/ebreen/solana-agent-toolkit</a>
      </p>
    </article>
  </section>
</BaseLayout>
