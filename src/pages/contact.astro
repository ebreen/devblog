---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact">
  <section class="page">
    <h1>Contact</h1>
    <p>
      If you are hiring or want to collaborate on frontend product work, I am happy to discuss timelines, goals, and
      the right scope for your team.
    </p>
    <p class="meta">I usually respond within 1–2 business days.</p>

    <section class="section" aria-labelledby="contact-methods">
      <h2 id="contact-methods">Ways to Reach Me</h2>
      <ul>
        <li>
          Email: <a href="mailto:hello@example.com">hello@example.com</a>
        </li>
        <li>
          LinkedIn: <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">linkedin.com/in/your-name</a>
        </li>
        <li>
          GitHub: <a href="https://github.com/" target="_blank" rel="noreferrer">github.com/your-name</a>
        </li>
      </ul>
    </section>
  </section>
</BaseLayout>
