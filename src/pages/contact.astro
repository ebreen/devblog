---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact">
  <section class="page">
    <h1>Contact</h1>
    <p>Contact route is available in the shared shell for traversal and keyboard interaction checks.</p>
    <p class="meta">route://contact</p>
    <div class="section">
      <p>
        The shell defaults to a dark theme on first paint and uses the same accent token across all primary routes via
        <code>--accent</code>.
      </p>
    </div>
  </section>
</BaseLayout>
