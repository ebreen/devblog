---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatBlogDate, getReadingTime, sortBlogEntries } from "../../lib/blog";

type Props = {
  entry: CollectionEntry<"blog">;
};

export async function getStaticPaths() {
  const entries = sortBlogEntries(await getCollection("blog"));
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title}>
  <article class="page post-page">
    <header class="post-header">
      <div class="meta-top">
        <time datetime={entry.data.date.toISOString()}>{formatBlogDate(entry.data.date)}</time>
        <span class="reading-time">{getReadingTime(entry)}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <hr class="title-divider" />
    </header>
    <section class="post-content">
      <Content />
    </section>
  </article>
</BaseLayout>

<style>
  .post-page {
    max-width: 800px;
    margin-inline: auto;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .meta-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .title-divider {
    border: 0;
    height: 2px;
    background: var(--accent);
    margin: 1.5rem 0 2rem;
    width: 100%;
  }

  .post-content :global(h2) {
    font-size: 1.8rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .post-content :global(pre) {
    margin: 2rem 0;
    padding: 1.5rem;
    background: #1a1a1a;
    border: 0;
    border-radius: 4px;
    overflow-x: auto;
  }

  .post-content :global(code) {
    background: rgb(255 255 255 / 6%);
    border: 1px solid var(--border);
    border-radius: 0.35rem;
    padding: 0.08rem 0.35rem;
  }

  .post-content :global(pre code) {
    display: block;
    width: max-content;
    min-width: 100%;
    background: none;
    border: 0;
    border-radius: 0;
    padding: 0;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
</style>
