---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatBlogDate, getReadingTime, sortBlogEntries } from "../../lib/blog";

const entries = sortBlogEntries(await getCollection("blog"));
---

<BaseLayout title="Blog">
  <section class="page">
    <h1>Blog</h1>
    <p>Thoughts on building, shipping, and maintaining a minimal developer portfolio.</p>

    {
      entries.length === 0 ? (
        <div class="section" role="status">
          <p>No blog posts are available yet. Check back soon.</p>
        </div>
      ) : (
        <ul class="blog-list">
          {entries.map((entry) => (
            <li class="section blog-item">
              <h2>
                <a href={`/blog/${entry.slug}`}>{entry.data.title}</a>
              </h2>
              <p class="meta">
                <time datetime={entry.data.date.toISOString()}>{formatBlogDate(entry.data.date)}</time>
                {" · "}
                <span>{getReadingTime(entry)}</span>
              </p>
              <ul class="tag-list">
                {entry.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .blog-list,
  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .blog-list {
    display: grid;
    gap: 1rem;
  }

  .blog-item h2 {
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .blog-item h2 a {
    color: inherit;
    text-decoration: none;
  }

  .blog-item h2 a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.75rem;
  }

  .tag {
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.2rem 0.55rem;
  }
</style>
