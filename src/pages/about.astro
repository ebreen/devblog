---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <section class="page">
    <h1>About</h1>
    <p>This route confirms the shared shell is stable on direct loads and nav traversal.</p>
    <p class="meta">route://about</p>
    <div class="section">
      <p>
        Typography baseline is configured globally via <code>--font-sans</code> and <code>--font-mono</code> theme
        tokens.
      </p>
    </div>
  </section>
</BaseLayout>
